{
  "name": "apertur/sdk",
  "description": "Official Apertur SDK for PHP",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Apertur\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Apertur\\Sdk\\Tests\\": "tests/"
    }
  }
}
